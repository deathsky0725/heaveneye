# Heaveneye — Environment Configuration
# Copy this file to .env and fill in your values.
# All keys are optional unless you want that feature.

# =============================================================================
# SERVER CONFIGURATION
# =============================================================================

# Port for the Hono backend API server (default: 7878)
HEAVENEYE_PORT=7878

# Port for the Vite web frontend dev server (default: 5173)
HEAVENEYE_WEB_PORT=5173

# =============================================================================
# HERMES INTEGRATION
# =============================================================================

# Path to your Hermes home directory (default: ~/.hermes)
HERMES_HOME=~/.hermes

# =============================================================================
# DISCORD NOTIFICATIONS
# =============================================================================

# Discord webhook URL for task-completion notifications and alerts.
# Format: https://discord.com/api/webhooks/{webhook_id}/{webhook_token}
# Get yours from Discord channel settings → Integrations → Webhooks
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR_WEBHOOK_ID/YOUR_WEBHOOK_TOKEN

# =============================================================================
# LLM PROVIDER KEYS
# =============================================================================

# Anthropic — for Claude models via direct API
# Get from: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# OpenAI — for GPT-4 / o1 models via direct API
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# OpenRouter — aggregated access to 100+ models (Mistral, Llama, etc.)
# Get from: https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Google (Gemini) — for Gemini models via AI Studio
# Get from: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=AIzaSyxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# MiniMax — for MiniMax-M2.7 and other MiniMax models
# Get from: https://platform.minimax.io/
MINIMAX_API_KEY=eyJhxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Groq — fast free tier for Llama/Mixtral
# Get from: https://console.groq.com/keys
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# =============================================================================
# AGENT CLI PATHS (optional — auto-detected if omitted)
# =============================================================================

# Path to Claude Code CLI (default: searches $PATH)
# CLAUDE_BIN=/opt/homebrew/bin/claude

# Path to Antigravity CLI / agy (default: searches $PATH)
# AGY_BIN=/Users/ben/.local/bin/agy

# Path to Hermes CLI (default: searches $PATH)
# HERMES_BIN=/Users/ben/.local/bin/hermes

# =============================================================================
# TAURI (Desktop App)
# =============================================================================

# Enable devtools in production builds (default: false)
# TAURI_DEBUG=false

# =============================================================================
# NOTES
# =============================================================================
# - Keys left empty will be prompted for in the Heaveneye first-run wizard.
# - Never commit your .env file to version control — it is in .gitignore.
# - Provider keys can also be configured per-profile in config.yaml files.